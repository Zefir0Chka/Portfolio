<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Header / app bar -->
        <LinearLayout
            android:id="@+id/user_block"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:background="@drawable/bg_glass_card"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp"
            android:elevation="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btn_menu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/menu"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:tint="?attr/km_textPrimary" />

            <ImageView
                android:id="@+id/img_avatar"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginStart="10dp"
                android:contentDescription="@string/user_avatar"
                android:src="@android:drawable/sym_def_app_icon" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txt_nickname"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="?attr/km_textPrimary"
                    tools:text="User123" />

                <TextView
                    android:id="@+id/txt_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/select_planet_subtitle"
                    android:textSize="12sp"
                    android:textColor="?attr/km_textSecondary" />

                <TextView
                    android:id="@+id/txt_header_meta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:background="@drawable/bg_task_panel"
                    android:paddingStart="8dp"
                    android:paddingTop="2dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="2dp"
                    android:text="Курс: Java | 0"
                    android:textColor="?attr/km_textPrimary"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_theme"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:thumbIcon="@drawable/ic_rocket_toggle"
                app:thumbIconTint="@android:color/white"
                app:thumbTint="@color/accent_primary"
                app:trackTint="#66FFFFFF" />
        </LinearLayout>

        <!-- Solar system block -->
        <FrameLayout
            android:id="@+id/solar_system_block"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="12dp"
            app:layout_constraintBottom_toTopOf="@+id/bottom_bar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/user_block">

            <ImageView
                android:id="@+id/img_stars_overlay_1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0.45"
                android:scaleType="fitXY"
                android:src="@drawable/bg_stars_realistic" />

            <ImageView
                android:id="@+id/img_stars_overlay_2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0.25"
                android:rotation="7"
                android:scaleType="fitXY"
                android:src="@drawable/bg_stars_realistic" />

            <ImageView
                android:id="@+id/img_comet_1"
                android:layout_width="46dp"
                android:layout_height="18dp"
                android:alpha="0"
                android:src="@drawable/ic_comet"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/img_comet_2"
                android:layout_width="42dp"
                android:layout_height="16dp"
                android:alpha="0"
                android:src="@drawable/ic_comet"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/img_center_object"
                android:layout_width="130dp"
                android:layout_height="130dp"
                android:layout_gravity="center"
                android:contentDescription="Center object"
                android:src="@drawable/ic_sun" />

            <ImageView
                android:layout_width="300dp"
                android:layout_height="300dp"
                android:layout_gravity="center"
                android:alpha="0.35"
                android:src="@drawable/orbit_ring" />

            <ImageView
                android:layout_width="390dp"
                android:layout_height="390dp"
                android:layout_gravity="center"
                android:alpha="0.25"
                android:src="@drawable/orbit_ring" />

            <ImageView
                android:layout_width="480dp"
                android:layout_height="480dp"
                android:layout_gravity="center"
                android:alpha="0.18"
                android:src="@drawable/orbit_ring" />

            <!-- Orbit containers (we rotate these in code) -->
            <FrameLayout
                android:id="@+id/orbit_1"
                android:layout_width="300dp"
                android:layout_height="300dp"
                android:layout_gravity="center">

                <ImageView
                    android:id="@+id/planet_java"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_gravity="top|center_horizontal"
                    android:contentDescription="Java"
                    android:src="@drawable/planet_java" />

                <ImageView
                    android:id="@+id/logo_java"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="24dp"
                    android:alpha="0"
                    android:src="@drawable/lang_java" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/orbit_2"
                android:layout_width="390dp"
                android:layout_height="390dp"
                android:layout_gravity="center">

                <ImageView
                    android:id="@+id/planet_kotlin"
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    android:layout_gravity="top|center_horizontal"
                    android:contentDescription="Kotlin"
                    android:src="@drawable/planet_kotlin" />

                <ImageView
                    android:id="@+id/logo_kotlin"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="24dp"
                    android:alpha="0"
                    android:src="@drawable/lang_kotlin" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/orbit_3"
                android:layout_width="480dp"
                android:layout_height="480dp"
                android:layout_gravity="center">

                <ImageView
                    android:id="@+id/planet_python"
                    android:layout_width="86dp"
                    android:layout_height="86dp"
                    android:layout_gravity="top|center_horizontal"
                    android:contentDescription="Python"
                    android:src="@drawable/planet_python" />

                <ImageView
                    android:id="@+id/logo_python"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="30dp"
                    android:alpha="0"
                    android:src="@drawable/lang_python" />

                <ImageView
                    android:id="@+id/planet_1c"
                    android:layout_width="62dp"
                    android:layout_height="62dp"
                    android:layout_gravity="center|end"
                    android:contentDescription="1C"
                    android:src="@drawable/planet_1c" />

                <ImageView
                    android:id="@+id/logo_1c"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_gravity="center|end"
                    android:layout_marginEnd="20dp"
                    android:alpha="0"
                    android:src="@drawable/lang_1c" />

                <ImageView
                    android:id="@+id/planet_cpp"
                    android:layout_width="74dp"
                    android:layout_height="74dp"
                    android:layout_gravity="bottom|center_horizontal"
                    android:contentDescription="C++"
                    android:src="@drawable/planet_cpp" />

                <ImageView
                    android:id="@+id/logo_cpp"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="22dp"
                    android:alpha="0"
                    android:src="@drawable/lang_cpp" />

                <ImageView
                    android:id="@+id/planet_csharp"
                    android:layout_width="78dp"
                    android:layout_height="78dp"
                    android:layout_gravity="center|start"
                    android:contentDescription="C#"
                    android:src="@drawable/planet_csharp" />

                <ImageView
                    android:id="@+id/logo_csharp"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center|start"
                    android:layout_marginStart="18dp"
                    android:alpha="0"
                    android:src="@drawable/lang_csharp" />
            </FrameLayout>
        </FrameLayout>

        <!-- Bottom fixed buttons -->
        <LinearLayout
            android:id="@+id/bottom_bar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_bottom_bar"
            android:orientation="vertical"
            android:padding="14dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_tests"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/tests_and_checks" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_tasks"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/tasks" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_continue"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/continue_learning" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigation_view"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>