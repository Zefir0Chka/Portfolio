<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_admin_home"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/go_home" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_admin_reviews"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/reviews_and_suggestions" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_admin_theme"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/admin_cabinet"
            android:textSize="22sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_glass_card"
            android:orientation="horizontal"
            android:padding="12dp">

            <ImageView
                android:id="@+id/admin_avatar_preview"
                android:layout_width="86dp"
                android:layout_height="86dp"
                android:clickable="true"
                android:focusable="true"
                android:src="@android:drawable/star_big_on" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Панель администратора"
                    android:textColor="?attr/km_textPrimary"
                    android:textStyle="bold"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Управление пользователями, кодами доступа и отзывами"
                    android:textColor="?attr/km_textSecondary"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <EditText
            android:id="@+id/input_admin_nickname"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/nickname_hint" />

        <EditText
            android:id="@+id/input_admin_email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/email_hint" />

        <EditText
            android:id="@+id/input_admin_phone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/phone_hint" />

        <EditText
            android:id="@+id/input_admin_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:enabled="false"
            android:hint="@string/status_hint" />

        <TextView
            android:id="@+id/txt_admin_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_task_panel"
            android:padding="10dp" />

        <TextView
            android:id="@+id/txt_admin_stats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_task_panel"
            android:padding="10dp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txt_last_access_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txt_last_access_code_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_create_access_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/create_access_code" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_show_access_codes"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/show_access_codes" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_admin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/save_changes" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_admin_logout"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/logout" />
    </LinearLayout>
</ScrollView>
