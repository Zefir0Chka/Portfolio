<?xml version="1.0" encoding="UTF-8" standalone="yes"?><w:document xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main"><w:body><w:p><w:r><w:t xml:space="preserve">САНКТ-ПЕТЕРБУРГСКОЕ ГОСУДАРСТВЕННОЕ БЮДЖЕТНОЕ</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">ПРОФЕССИОНАЛЬНОЕ ОБРАЗОВАТЕЛЬНОЕ УЧРЕЖДЕНИЕ</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">«ИЖОРСКИЙ ПОЛИТЕХНИЧЕСКИЙ КОЛЛЕДЖ»</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">КУРСОВАЯ РАБОТА</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Тема:</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Разработка мобильного приложения с курсами по программированию</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">(Android-приложение KillMePlease_5.0)</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">По МДК 01.03 Разработка мобильных приложений</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Специальность 09.02.07 Информационные системы и программирование</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Студент: ____________________________  Группа 331С  Курс 3</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Руководитель: _________________________</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Санкт‑Петербург, 2026</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">СОДЕРЖАНИЕ</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">ВВЕДЕНИЕ</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">ГЛАВА 1. АНАЛИЗ ПРЕДМЕТНОЙ ОБЛАСТИ</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">1.1. Описание предметной области</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">1.2. Функциональные требования</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">1.3. Нефункциональные требования</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">1.4. Выбор среды разработки и технологий</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">ГЛАВА 2. РЕАЛИЗАЦИЯ ПРОЕКТА В СРЕДЕ РАЗРАБОТКИ</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">2.1. Разработка интерфейса</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">2.1.1. Структура приложения и экранов</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">2.1.2. Реализация адаптивных макетов</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">2.1.3. Реализация ключевых экранов</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">2.1.4. Работа с темой, стилями и анимациями</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">2.2. Разработка логики приложения</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">2.2.1. Архитектура приложения</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">2.2.2. Авторизация и профили пользователей</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">2.2.3. Курсы и темы (TopicsRepository)</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">2.2.4. Практика и проверка заданий (CodePracticeActivity)</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">2.2.5. Настройки интерфейса (UiSettings)</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">2.3. Структура базы данных SQLite (DbHelper)</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">ЗАКЛЮЧЕНИЕ</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">СПИСОК ИСПОЛЬЗОВАННЫХ ИСТОЧНИКОВ</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">ПРИЛОЖЕНИЯ</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">ВВЕДЕНИЕ</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Актуальность: мобильные приложения позволяют изучать программирование в удобном формате. Для повышения вовлечённости используется игровая механика (монеты, прогресс) и визуальная космическая тема.</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Цель: разработать Android‑приложение с курсами по программированию, теорией и практикой с автоматической проверкой.</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Задачи: спроектировать UI, реализовать хранение данных в SQLite, сделать курсы/темы, добавить практику с проверкой вывода, реализовать настройки интерфейса и кабинеты пользователя/администратора.</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">ГЛАВА 1. АНАЛИЗ ПРЕДМЕТНОЙ ОБЛАСТИ</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">1.1. Описание предметной области</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Предметная область — обучение основам программирования через курсы по языкам (Java, Kotlin, Python, 1C, C++, C#). Пользователь изучает темы, выполняет задания и получает награды.</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">1.2. Функциональные требования</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Регистрация/вход (в т.ч. по коду доступа для студентов)</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Выбор курса (языка) и список тем</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Просмотр теории темы (текст + видео + примеры)</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Практика: ввод кода, запуск, проверка результата</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Начисление монет только при корректном решении</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Прогресс по темам и курсам</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Настройки: тема, размер текста, цвет акцента, режим чтения</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Кабинет пользователя и кабинет администратора</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Отзывы и статистика (для администратора)</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">1.3. Нефункциональные требования</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Поддержка Android 7.0+ (minSdk 24)</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Хранение данных локально (SQLite)</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Удобный интерфейс, анимации, доступность текста</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Защита от повторного начисления монет за одно задание</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">1.4. Выбор среды разработки и технологий</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Среда: Android Studio</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Язык: Java (Android SDK)</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- UI: XML + Material Components</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- База данных: SQLite (SQLiteOpenHelper)</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">ГЛАВА 2. РЕАЛИЗАЦИЯ ПРОЕКТА В СРЕДЕ РАЗРАБОТКИ</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">2.1. Разработка интерфейса</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">2.1.1. Структура приложения и экранов</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">В приложении реализованы экраны: MainActivity (главная), CoursesActivity (темы курса), TopicDetailActivity (тема), CodePracticeActivity (практика), SettingsActivity (настройки), ProfileActivity (кабинет), AdminActivity (кабинет администратора), ReviewsActivity, TestsActivity и др.</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">2.1.2. Реализация адаптивных макетов</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Использованы ConstraintLayout/ScrollView и компоненты Material3 для масштабирования под разные экраны.</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">2.1.3. Реализация ключевых экранов</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Главный экран выполнен в космическом стиле: планеты‑курсы, звёздный фон, кометы, анимации и параллакс‑эффект.</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">2.1.4. Работа с темой, стилями и анимациями</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Добавлены анимации переходов между экранами, интерактивный отклик на нажатия, переключение темы (тумблер‑ракета).</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">2.2. Разработка логики приложения</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">2.2.1. Архитектура приложения</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Архитектура построена на Activities + вспомогательные классы DbHelper, TopicsRepository, UiSettings.</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">2.2.2. Авторизация и профили пользователей</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Реализована регистрация и вход. Профиль хранит ник, контакты, аватар, монеты и выбранный язык. Есть кабинет пользователя и кабинет администратора.</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">2.2.3. Курсы и темы (TopicsRepository)</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Темы формируются по выбранному языку. Для каждой темы есть теория, видео и практика.</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">2.2.4. Практика и проверка заданий (CodePracticeActivity)</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Проверка строгая: монеты выдаются только при корректном выводе и выполнении требований по теме. Повторно за ту же тему монеты не начисляются.</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">2.2.5. Настройки интерфейса (UiSettings)</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Пользователь может менять тему, размер текста, цвет акцента и включать режим чтения.</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">2.3. Структура базы данных SQLite (DbHelper)</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Таблицы: users, session, language_progress, solved_tasks, reviews, access_codes.</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">ЗАКЛЮЧЕНИЕ</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Разработано Android‑приложение с курсами по программированию, встроенной практикой, прогрессом и настройками. Проект соответствует поставленным требованиям.</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">СПИСОК ИСПОЛЬЗОВАННЫХ ИСТОЧНИКОВ</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">1) Android Developers Documentation</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">2) Material Components for Android</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">3) SQLite Documentation</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">ПРИЛОЖЕНИЯ</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Приложение А: Основные файлы проекта (MainActivity.java, DbHelper.java, TopicsRepository.java, UiSettings.java и др.).</w:t></w:r></w:p></w:body></w:document>